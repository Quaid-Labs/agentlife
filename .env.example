# AgentLife Benchmark Configuration
# Copy to .env and fill in values

# Required for Mem0 evaluation (OpenAI embeddings + judge)
OPENAI_API_KEY=your-openai-key-here

# Required for Claude-based extraction (or use Claude Code CLI)
# ANTHROPIC_API_KEY=your-anthropic-key-here

# Optional: Override workspace root (default: ~/clawd)
# CLAWDBOT_WORKSPACE=/path/to/workspace

# Optional: Override memory database path
# MEMORY_DB_PATH=/path/to/memory.db

# Optional: VM benchmark settings
# AGENTLIFE_VM_IP=192.168.64.3
# AGENTLIFE_VM_USER=admin
# AGENTLIFE_VM_PASS=admin
