# AgentLife Benchmark Environment Template
# Optional convenience file for local-only scripts that still read env vars.
# Canonical machine setup now lives in .agentlife-benchmark.local.json.

# Required for Mem0 evaluation (OpenAI embeddings + judge)
OPENAI_API_KEY=your-openai-key-here

# Direct Anthropic API access for benchmark runs.
# Generate with: claude setup-token
# Then paste the token here as a benchmark-only credential.
# BENCHMARK_ANTHROPIC_OAUTH_TOKEN=sk-ant-oat01-...

# Optional fallback for direct Anthropic API runs when no benchmark OAuth token is set.
# ANTHROPIC_API_KEY=your-anthropic-key-here

# Optional: Override workspace root (default: ~/clawd)
# CLAWDBOT_WORKSPACE=/path/to/workspace

# Optional: Override memory database path
# MEMORY_DB_PATH=/path/to/memory.db

# Optional: VM benchmark settings
# AGENTLIFE_VM_IP=192.168.64.3
# AGENTLIFE_VM_USER=admin
# AGENTLIFE_VM_PASS=admin
